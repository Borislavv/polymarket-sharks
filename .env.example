# --- Database ---
DATABASE_URL=postgres://watchtower:watchtower@postgres:5432/watchtower?sslmode=disable
POSTGRES_USER=watchtower
POSTGRES_PASSWORD=watchtower
POSTGRES_DB=watchtower

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BETS_CHAT_ID=
TELEGRAM_CLUSTERS_CHAT_ID=
TELEGRAM_NEWS_CHAT_ID=

# --- Polymarket public surfaces ---
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# --- Intervals (Go duration: 30s, 2m, 1h) ---
DISCOVERY_INTERVAL=5m
HOLDER_SCAN_INTERVAL=10m
WATCHED_WALLET_POLL_INTERVAL=1m
CLUSTER_SCAN_INTERVAL=90s
NEWS_SCAN_INTERVAL=5m

# --- Hotset ---
# HOTSET_MARKETS_LIMIT is the canonical name (recommended 400+).
# HOTSET_MAX_MARKETS is accepted as a fallback for backward compatibility.
# If active/open markets > 80 raise this to 400 for adequate coverage.
HOTSET_MARKETS_LIMIT=400
# HOTSET_MAX_MARKETS=400  # legacy alias

# --- Candidate discovery (v4) ---
HOLDER_DEEP_SCAN_SIZE=100
CANDIDATE_TOP_MARKETS_LIMIT=400
LEADERBOARD_TOP_WALLETS_LIMIT=200
LARGE_TRADE_MIN_NOTIONAL_USD=20000

# --- Historical backfill (v4) ---
HISTORY_BACKFILL_INTERVAL=2m
HISTORY_BACKFILL_BATCH_SIZE=30
HISTORY_BACKFILL_CONCURRENCY=4
HISTORY_BACKFILL_TRADE_PAGE_SIZE=500
HISTORY_BACKFILL_CLOSED_PAGE_SIZE=500
HISTORY_BACKFILL_MAX_TRADE_PAGES=20
HISTORY_BACKFILL_MAX_CLOSED_PAGES=20

# --- Shark strategy (legacy v3 knobs retained for diagnostics/reconciliation) ---
SHARK_MIN_TRADES=100
SHARK_MIN_CLOSED_POSITIONS=30
SHARK_MIN_SCORE=70
SHARK_MIN_CONFIDENCE=0.65
SHARK_MAX_STALE_DAYS=180

# --- Shark v4 historical gates (the only hard gates in v4) ---
SHARK_HIST_MIN_CLOSED_POSITIONS=25
SHARK_HIST_MIN_ROI=0.10
SHARK_HIST_MIN_WIN_RATE=0.75
SHARK_HIST_MIN_AVG_STAKE_USD=10000

# Per-bet dust threshold below which individual SHARK_BET alerts are
# suppressed when ALERT_PROFIT_GATE_ENABLED=false (legacy mode).
# When profit gate is enabled this is only an absolute dust floor.
SHARK_ALERT_MIN_NOTIONAL_USD=10000

# --- Profit-tier alert gate (SHARK_BET) ---
# Replaces simple min_notional with a stake/odds/profit-aware gate.
# Each trade is classified into a tier by notional and must satisfy BOTH
# min_odds AND min_profit_if_win for that tier to emit a user alert.
# profit_if_win = notional * (1/price - 1)  payoff_if_win = notional / price
ALERT_PROFIT_GATE_ENABLED=true

# Tiny: notional < 500 — only alert if very asymmetric
ALERT_TINY_MAX_NOTIONAL_USD=500
ALERT_TINY_MIN_ODDS=10
ALERT_TINY_MIN_PROFIT_USD=4000

# Small: 500 ≤ notional < 2000 — need high odds / high profit
ALERT_SMALL_MAX_NOTIONAL_USD=2000
ALERT_SMALL_MIN_ODDS=7
ALERT_SMALL_MIN_PROFIT_USD=7000

# Medium: 2000 ≤ notional < 10000 — need meaningful odds/profit
ALERT_MEDIUM_MAX_NOTIONAL_USD=10000
ALERT_MEDIUM_MIN_ODDS=4
ALERT_MEDIUM_MIN_PROFIT_USD=15000

# Large: 10000 ≤ notional < 80000 — lower odds accepted
ALERT_LARGE_MAX_NOTIONAL_USD=80000
ALERT_LARGE_MIN_ODDS=2
ALERT_LARGE_MIN_PROFIT_USD=25000

# Mega: notional >= 80000 — alert almost always if wallet qualified
ALERT_MEGA_MIN_NOTIONAL_USD=80000
ALERT_MEGA_MIN_ODDS=1.15
ALERT_MEGA_MIN_PROFIT_USD=10000

# --- Cluster profit gate (additive to existing notional/quality gates) ---
# Cluster emits alert only if: total_profit_if_win >= min OR
# (total_notional >= CLUSTER_MIN_TOTAL_NOTIONAL_USD AND avg_odds >= min)
CLUSTER_MIN_TOTAL_PROFIT_USD=25000
CLUSTER_MIN_AVG_ODDS=2

# --- Insider strategy ---
INSIDER_MAX_LIFETIME_TRADES=3
INSIDER_MAX_LIFETIME_MARKETS=3
INSIDER_MIN_NOTIONAL_USD=20000
INSIDER_MIN_SCORE=70
INSIDER_MIN_CONFIDENCE=0.60
INSIDER_LOW_PROB_PRICE_THRESHOLD=0.20
INSIDER_MIN_ODDS=3.0
INSIDER_MAX_LIFETIME_FOR_CAPTURE=10

# --- Cluster detection ---
CLUSTER_WINDOW_BEFORE=3h
CLUSTER_WINDOW_AFTER=3h
CLUSTER_MIN_WALLETS=2
CLUSTER_MIN_TOTAL_NOTIONAL_USD=5000
CLUSTER_MIN_QUALITY_SCORE=60

# --- News (Next.js layer, internal/non-official) ---
NEXTJS_NEWS_ENABLED=false
NEXTJS_BUILD_ID_TTL=30m

# --- Rate limits (req/sec) ---
GAMMA_RPS_LIMIT=8
DATA_API_RPS_LIMIT=24
CLOB_RPS_LIMIT=8
TELEGRAM_RPS_LIMIT=1

# --- Price sampler (feeds CLV proxy) ---
PRICE_SAMPLER_INTERVAL=2m
PRICE_SAMPLER_MAX_PER_CYCLE=40

# --- Telegram retry / safety ---
TELEGRAM_RETRY_INTERVAL=30s
TELEGRAM_MAX_ATTEMPTS=5

# Master alerting kill-switch.
# When false: alert_decisions and telegram_deliveries are persisted with
# status='skipped' but no Telegram API call is made. Use for staging/dry-run.
# Default: true (alerts on).
ALERTING_ENABLED=true

# --- Position lifecycle / exit alerts ---
# Track open positions of watched wallets and emit POSITION_EXIT alerts
# when they sell/close. Disable LIFECYCLE_ENABLED to fully bypass tracking
# (and exit alerts). Default both: true.
LIFECYCLE_ENABLED=true
EXIT_ALERTS_ENABLED=true
# Fraction of remaining size that still counts as "closed" (0.05 = within 5%).
EXIT_FULL_CLOSE_TOLERANCE=0.05
# Include exit trades in cluster scans (off by default — clusters track entries).
EXIT_CLUSTER_ENABLED=false

# --- Runtime ---
HTTP_TIMEOUT=20s
WORKER_CONCURRENCY=6
LOG_LEVEL=info
METRICS_ADDR=:9090

# --- Categories to discover (comma-separated tag slugs) ---
TARGET_CATEGORIES=politics,geopolitics,war,military,elections

# Optional dashboard base
INTERNAL_DASHBOARD_BASE_URL=
